{
  "manifest_version": 3,
  "name": "ShopFriend (dev)",
  "version": "0.0.1",
  "description": "Smart Shopper companion — development build",
  "action": {
    "default_title": "ShopFriend"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "sidePanel",
    "scripting",
    "tabs",
    "windows"
  ],
  "host_permissions": [
    "https://www.amazon.com/*",
    "https://madmuscles.com/*",
    "https://www.madmuscles.com/*",
    "http://localhost:3000/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "js": [
        "assets/content-script.ts-loader-BlTEdd9m.js"
      ],
      "matches": [
        "https://shopfriend-build-placeholder.invalid/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/*.js",
        "assets/*.css"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://shopfriend-build-placeholder.invalid/*"
      ],
      "resources": [
        "assets/extension-ui-CnmtFWL5.css",
        "assets/insight-session-context-CwgEjDEn.js",
        "assets/request-product-snapshot-CU7nJuHv.js",
        "assets/content-script.ts-CRyKXfIw.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
