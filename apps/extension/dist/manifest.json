{
  "manifest_version": 3,
  "name": "ShopFriend (dev)",
  "version": "0.0.1",
  "description": "Smart Shopper companion — development build",
  "action": {
    "default_title": "ShopFriend",
    "default_popup": "src/popup/index.html"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "sidePanel",
    "scripting",
    "tabs",
    "windows"
  ],
  "host_permissions": [
    "https://www.amazon.com/*",
    "https://madmuscles.com/*",
    "https://www.madmuscles.com/*",
    "http://localhost:3000/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "js": [
        "assets/content-script.ts-loader-CFpdUzVD.js"
      ],
      "matches": [
        "https://shopfriend-build-placeholder.invalid/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/*.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://shopfriend-build-placeholder.invalid/*"
      ],
      "resources": [
        "assets/shopfriend-messages-C6ZjJGfZ.js",
        "assets/site-extractor-config-B9BecTau.js",
        "assets/content-script.ts-ia2G716j.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
